{
  "name": "ubugeeei",
  "version": "3.1.4",
  "description": "Hi! I'm ubugeeei, Vue.js team member, author of chibivue, vize, and corsa-bind",
  "keywords": [
    "card",
    "chibivue",
    "cli",
    "npx",
    "vue"
  ],
  "homepage": "https://wtrclred.io",
  "bugs": {
    "url": "https://github.com/ubugeeei/ubugeeei/issues"
  },
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei/ubugeeei.git"
  },
  "funding": "https://github.com/sponsors/ubugeeei",
  "bin": {
    "ubugeeei": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run pack:dry-run",
    "dev": "node dist/cli.mjs",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "lint": "vp lint .",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "watch": "vp pack --watch"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.21"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
